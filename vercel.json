{
  "version": 2,
  "buildCommand": "pnpm build:vercel",
  "outputDirectory": "dist/public",
  "installCommand": "pnpm install",
  "functions": {
    "api/server.ts": {
      "includeFiles": "server/**",
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/server"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
